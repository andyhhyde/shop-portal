generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String
  role          String       @default("artist")
  phone         String?
  createdAt     DateTime     @default(now())

  eventRSVPs       EventRSVP[]
  boothPayments    BoothPayment[]
  events           Event[]         @relation("EventCreator")
  submittedCredits ReceiptCredit[] @relation("SubmittedCredits")
  reviewedCredits  ReceiptCredit[] @relation("ReviewedCredits")
  suggestions          Suggestion[]
  notifications         Notification[]
  notificationSettings  NotificationSettings?
  pushSubscriptions     PushSubscription[]
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String?
  type        String      @default("meeting")
  createdById String
  createdAt   DateTime    @default(now())

  createdBy   User        @relation("EventCreator", fields: [createdById], references: [id])
  rsvps       EventRSVP[]
}

model EventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model BoothPayment {
  id        String    @id @default(cuid())
  userId    String
  amount    Float
  dueDate   DateTime
  paidDate  DateTime?
  status    String    @default("pending")
  notes     String?
  period    String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("general")
  quantity    Float    @default(0)
  unit        String   @default("units")
  reorderAt   Float    @default(5)
  supplier    String?
  orderUrl    String?
  notes       String?
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
}

model ReceiptCredit {
  id           String    @id @default(cuid())
  userId       String
  period       String
  amount       Float
  description  String
  imagePath    String?
  status       String    @default("pending")
  reviewNote   String?
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime  @default(now())

  user         User      @relation("SubmittedCredits", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?     @relation("ReviewedCredits", fields: [reviewedById], references: [id])
}

model Suggestion {
  id        String   @id @default(cuid())
  userId    String
  body      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("rent_reminder")
  read      Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  enabled        Boolean @default(true)
  daysBeforeDue  Int     @default(7)
  recurringEvery Int     @default(3)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
